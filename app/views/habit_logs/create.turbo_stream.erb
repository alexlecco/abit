<%= turbo_stream.replace "cell-#{@habit.id}-#{params[:date]}" do %>
  <div class="h-12 flex items-center justify-center border-b border-slate-700/30 <%= params[:date] == Date.current.to_s ? 'bg-teal-900/20' : '' %>"
       id="cell-<%= @habit.id %>-<%= params[:date] %>">
    <%= button_to habit_habit_log_path(@habit, "current", date: params[:date]),
                  method: :delete,
                  class: "w-9 h-9 rounded-full flex items-center justify-center transition-all hover:scale-110 cursor-pointer shadow-lg",
                  style: "background-color: #{@habit.color};",
                  data: { turbo_stream: true } do %>
      <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
    <% end %>
  </div>
<% end %>

<%= turbo_stream.replace "habit-#{@habit.id}-current" do %>
  <span class="font-semibold text-slate-200" id="habit-<%= @habit.id %>-current"><%= @habit.current_streak %></span>
<% end %>

<%= turbo_stream.replace "habit-#{@habit.id}-longest" do %>
  <span class="font-semibold text-slate-200" id="habit-<%= @habit.id %>-longest"><%= @habit.longest_streak %></span>
<% end %>
