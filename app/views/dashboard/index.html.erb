<% content_for :title, t("dashboard.title") %>

<% unless user_signed_in? %>
  <div class="flex min-h-screen items-center justify-center">
    <div class="text-center">
      <div class="text-7xl mb-6 font-bold text-teal-400 tracking-widest">abit</div>
      <p class="text-slate-400 text-lg mb-10">Track your habits. Build your chains.</p>
      <%= form_with url: user_google_oauth2_omniauth_authorize_path,
                    method: :post,
                    id: "google-login-form",
                    html: { target: "google-popup", data: { turbo: "false" } } do |f| %>
        <button type="submit" onclick="openGooglePopup(event)"
                class="inline-flex items-center gap-3 bg-white text-gray-800 font-semibold px-8 py-3 rounded-xl hover:bg-gray-100 transition-colors shadow-lg text-base mx-auto">
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Sign in with Google
        </button>
      <% end %>
    </div>
  </div>
<% else %>

<div class="flex min-h-screen relative">
  <% if @habits.empty? %>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center">
        <div class="text-6xl mb-4">🔗</div>
        <p class="text-slate-400 text-lg mb-2"><%= t("dashboard.empty_title") %></p>
        <p class="text-slate-500 text-sm mb-6"><%= t("dashboard.empty_subtitle") %></p>
        <%= link_to t("dashboard.create_first"), new_habit_path, class: "bg-teal-500 hover:bg-teal-600 text-white font-medium px-6 py-3 rounded-lg transition-colors" %>
      </div>
    </div>
  <% else %>

    <!-- Dates column -->
    <div class="flex-shrink-0 w-28 sticky left-0 bg-slate-900 z-10">
      <div class="h-44"></div>
      <% @days.each do |day| %>
        <div class="h-12 flex flex-col justify-center px-3 border-b border-slate-700/30 <%= day == Date.current ? 'bg-teal-900/20' : '' %>">
          <span class="text-xs text-slate-300 font-medium uppercase tracking-wide"><%= day.strftime("%b %-d") %></span>
          <span class="text-xs text-slate-500"><%= day.strftime("%A")[0..2].upcase %></span>
        </div>
      <% end %>
    </div>

    <!-- Habit chains scroll area -->
    <div class="flex flex-1 overflow-x-auto">
      <% @habits.each do |habit| %>
        <div class="flex-shrink-0 w-36 border-l border-slate-700/30" id="habit-<%= habit.id %>">

          <!-- Habit card header -->
          <div class="h-44 p-3 flex flex-col justify-between border-b border-slate-700/50"
               style="background-color: <%= habit.color %>22; border-top: 3px solid <%= habit.color %>;">
            <div>
              <h3 class="font-bold text-xs text-white leading-tight tracking-wide"><%= habit.name.upcase %></h3>
              <% if habit.description.present? %>
                <p class="text-xs mt-1 text-slate-300 leading-tight line-clamp-2"><%= habit.description %></p>
              <% end %>
            </div>
            <div class="space-y-0.5">
              <div class="text-xs text-slate-400"><%= t("dashboard.longest") %> <span class="font-semibold text-slate-200" id="habit-<%= habit.id %>-longest"><%= habit.longest_streak %></span></div>
              <div class="text-xs text-slate-400"><%= t("dashboard.current_streak") %> <span class="font-semibold text-slate-200" id="habit-<%= habit.id %>-current"><%= habit.current_streak %></span></div>
              <div class="flex gap-2 mt-1.5 pt-1.5 border-t border-slate-700/50">
                <%= link_to edit_habit_path(habit), class: "text-slate-500 hover:text-slate-300 transition-colors" do %>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                <% end %>
                <%= button_to habit_path(habit), method: :delete, class: "text-slate-500 hover:text-red-400 transition-colors bg-transparent border-0 p-0 cursor-pointer", data: { turbo_confirm: t("dashboard.archive_confirm") } do %>
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8l1 12a2 2 0 002 2h8a2 2 0 002-2L19 8m-9 4v4m4-4v4"/>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Day cells -->
          <% @days.each do |day| %>
            <% completed = @completions.dig(habit.id)&.include?(day) %>
            <div class="h-12 flex items-center justify-center border-b border-slate-700/30 <%= day == Date.current ? 'bg-teal-900/20' : '' %>"
                 id="cell-<%= habit.id %>-<%= day %>">
              <% if day < habit.start_date %>
                <div class="w-9 h-9 rounded-full bg-slate-800/30"></div>
              <% elsif completed %>
                <%= button_to habit_habit_log_path(habit, "current", date: day.to_s),
                              method: :delete,
                              class: "w-9 h-9 rounded-full flex items-center justify-center transition-all hover:scale-110 cursor-pointer shadow-lg",
                              style: "background-color: #{habit.color};",
                              data: { turbo_stream: true } do %>
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                <% end %>
              <% else %>
                <%= button_to habit_habit_logs_path(habit, date: day.to_s),
                              method: :post,
                              class: "w-9 h-9 rounded-full border-2 border-slate-600 hover:border-slate-400 hover:scale-110 transition-all cursor-pointer",
                              data: { turbo_stream: true } do %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Add new chain -->
      <div class="flex-shrink-0 w-14 border-l border-slate-700/30">
        <div class="h-44 flex items-center justify-center">
          <%= link_to new_habit_path,
                      class: "flex flex-col items-center gap-1 text-slate-500 hover:text-teal-400 transition-colors group" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            <span class="text-xs font-medium tracking-widest uppercase [writing-mode:vertical-rl] rotate-180"><%= t("dashboard.add_new_chain") %></span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% end %>
