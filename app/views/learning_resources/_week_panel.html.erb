<% completed_count = resources.count(&:completed?) %>
<% total = resources.count %>

<% if total > 0 %>
  <div class="mb-4">
    <div class="flex justify-between text-xs text-slate-500 mb-1">
      <span><%= t("paths.learning.progress") %></span>
      <span><%= completed_count %>/<%= total %></span>
    </div>
    <div class="h-1.5 bg-slate-700/50 rounded-full overflow-hidden">
      <div class="h-full rounded-full transition-all duration-500"
           style="width: <%= total > 0 ? (completed_count.to_f / total * 100).round : 0 %>%; background-color: <%= habit.color %>;"></div>
    </div>
  </div>
<% end %>

<div id="week-<%= week %>-resources" class="space-y-3 mb-6">
  <% if resources.empty? %>
    <p class="text-slate-500 text-sm py-2"><%= t("paths.learning.empty_week") %></p>
  <% else %>
    <% resources.each do |resource| %>
      <%= render "learning_resources/resource", resource: resource, habit: habit %>
    <% end %>
  <% end %>
</div>

<div data-controller="inline-form">
  <button data-action="click->inline-form#toggle"
          class="flex items-center gap-2 text-slate-400 hover:text-teal-400 transition-colors text-sm font-medium">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    <%= t("paths.learning.add_resource") %>
  </button>

  <div data-inline-form-target="form" class="hidden mt-4 space-y-3">
    <%= form_with url: habit_learning_resources_path(habit),
          data: { turbo_stream: true, action: "turbo:submit-end->inline-form#reset" } do |f| %>
      <%= f.hidden_field :week_number, value: week %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <%= f.text_field :title,
              placeholder: t("paths.learning.title_placeholder"),
              class: "bg-slate-800/60 border border-slate-600 rounded-lg px-4 py-2 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-teal-500",
              required: true %>
        <%= f.url_field :url,
              placeholder: t("paths.learning.url_placeholder"),
              class: "bg-slate-800/60 border border-slate-600 rounded-lg px-4 py-2 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-teal-500" %>
      </div>
      <div class="flex gap-3 items-center">
        <%= f.select :resource_type,
              LearningResource::RESOURCE_TYPES.map { |t| [t.capitalize, t] },
              {},
              class: "bg-slate-800/60 border border-slate-600 rounded-lg px-3 py-2 text-white text-sm focus:outline-none focus:border-teal-500" %>
        <%= f.submit t("paths.learning.add_button"),
              class: "bg-teal-500 hover:bg-teal-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
