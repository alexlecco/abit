<div class="flex items-start gap-3 p-3 rounded-xl bg-slate-800/40 hover:bg-slate-800/60 transition-colors" id="learning-resource-<%= resource.id %>">
  <%= button_to habit_learning_resource_path(habit, resource),
        method: :patch,
        params: { learning_resource: { completed_at: "toggle" } },
        class: "flex-shrink-0 mt-0.5 w-5 h-5 rounded flex items-center justify-center transition-all hover:scale-110 cursor-pointer border-2 bg-transparent",
        style: resource.completed? ? "background-color: #{habit.color}; border-color: #{habit.color};" : "border-color: #475569;",
        data: { turbo_stream: true } do %>
    <% if resource.completed? %>
      <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
    <% end %>
  <% end %>

  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <% if resource.url.present? %>
        <%= link_to resource.title, resource.url, target: "_blank", rel: "noopener",
              class: "text-sm font-medium #{resource.completed? ? 'text-slate-400 line-through' : 'text-white'} hover:text-teal-300 transition-colors truncate" %>
      <% else %>
        <span class="text-sm font-medium <%= resource.completed? ? 'text-slate-400 line-through' : 'text-white' %>"><%= resource.title %></span>
      <% end %>
      <span class="text-xs px-2 py-0.5 rounded-full bg-slate-700/50 text-slate-400 flex-shrink-0"><%= resource.resource_type %></span>
    </div>
    <% if resource.notes.present? %>
      <p class="text-xs text-slate-500 mt-1"><%= resource.notes %></p>
    <% end %>
  </div>

  <%= button_to habit_learning_resource_path(habit, resource),
        method: :delete,
        class: "flex-shrink-0 text-slate-600 hover:text-red-400 transition-colors bg-transparent border-0 p-0 cursor-pointer",
        data: { turbo_stream: true, turbo_confirm: t("paths.learning.delete_confirm") } do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  <% end %>
</div>
