<% if @goal.nil? %>
  <%# Step 1: Define the main goal %>
  <div class="mb-8">
    <h2 class="text-lg font-semibold text-white mb-2"><%= t("paths.goals.define_goal_title") %></h2>
    <p class="text-slate-400 text-sm mb-5"><%= t("paths.goals.define_goal_subtitle") %></p>

    <%= form_with url: habit_goal_path(@habit), method: :post, data: { turbo_stream: true } do |f| %>
      <div class="space-y-3">
        <%= f.text_area :description,
              placeholder: t("paths.goals.goal_placeholder"),
              rows: 3,
              class: "w-full bg-slate-800/60 border border-slate-600 rounded-xl px-4 py-3 text-white text-sm placeholder-slate-500 focus:outline-none focus:border-teal-500 resize-none" %>
        <%= f.submit t("paths.goals.save_goal"),
              class: "bg-teal-500 hover:bg-teal-600 text-white text-sm font-medium px-6 py-2.5 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% else %>
  <%# Goal defined: show description + milestone tree + check-in %>
  <div class="mb-8 p-4 rounded-xl bg-slate-800/30 border border-slate-700/30">
    <p class="text-xs text-slate-500 uppercase tracking-wider mb-1"><%= t("paths.goals.goal_label") %></p>
    <p class="text-white font-medium"><%= @goal.description %></p>
  </div>

  <%# Milestone tree %>
  <div class="mb-8" id="milestone-tree">
    <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4"><%= t("paths.goals.milestones_title") %></h3>
    <%= render "weekly_milestones/tree", habit: @habit, goal: @goal, milestones: @milestones, current_week: @current_week %>
  </div>

  <%# Today's check-in %>
  <div id="daily-checkin-widget">
    <%= render "daily_checkins/checkin_widget", habit: @habit, today_checkin: @today_checkin, current_milestone: @current_milestone %>
  </div>
<% end %>
