<div class="px-6 py-5 border-b border-slate-700/30 flex items-center gap-4">
  <%= link_to root_path, class: "text-slate-400 hover:text-white transition-colors" do %>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  <% end %>

  <div class="flex-1">
    <div class="flex items-center gap-3">
      <div class="w-3 h-3 rounded-full" style="background-color: <%= habit.color %>;"></div>
      <h1 class="text-xl font-bold text-white"><%= habit.name %></h1>
      <% if habit.description.present? %>
        <span class="text-slate-400 text-sm hidden sm:inline"><%= habit.description %></span>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-4 text-sm">
    <div class="text-slate-400">
      <span class="text-slate-300 font-semibold"><%= habit.current_streak %></span>
      <span class="text-xs ml-1"><%= t("dashboard.current_streak") %></span>
    </div>
    <div class="text-slate-400">
      <span class="text-slate-300 font-semibold"><%= habit.longest_streak %></span>
      <span class="text-xs ml-1"><%= t("dashboard.longest") %></span>
    </div>
    <%= link_to edit_habit_path(habit), class: "text-slate-500 hover:text-slate-300 transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
      </svg>
    <% end %>
  </div>
</div>
