<div class="min-h-screen flex items-center justify-center p-6">
  <div class="w-full max-w-md bg-slate-800/50 rounded-2xl border border-slate-700/50 p-8 shadow-2xl">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-white"><%= habit.new_record? ? "New Chain" : "Edit Chain" %></h1>
      <p class="text-slate-400 text-sm mt-1">Track your daily habit and build a chain.</p>
    </div>

    <%= form_with model: habit, class: "space-y-5" do |f| %>
      <% if habit.errors.any? %>
        <div class="bg-red-900/30 border border-red-700/50 rounded-lg p-3">
          <% habit.errors.full_messages.each do |msg| %>
            <p class="text-red-400 text-sm"><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Habit Name", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
        <%= f.text_field :name,
            placeholder: "e.g. Go jogging, Read 30 min...",
            class: "w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition" %>
      </div>

      <div>
        <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
        <%= f.text_area :description,
            placeholder: "e.g. 30 min of exercise per day",
            rows: 2,
            class: "w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-2.5 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition resize-none" %>
      </div>

      <div>
        <%= f.label :color, "Color", class: "block text-sm font-medium text-slate-300 mb-2" %>
        <div class="flex gap-3 flex-wrap">
          <% Habit::COLORS.each do |color| %>
            <label class="cursor-pointer">
              <%= f.radio_button :color, color, class: "sr-only peer" %>
              <span class="w-8 h-8 rounded-full block border-2 border-transparent peer-checked:border-white peer-checked:scale-110 transition-all hover:scale-105"
                    style="background-color: <%= color %>;"
                    title="<%= color %>"></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit habit.new_record? ? "Create Chain" : "Update Chain",
            class: "flex-1 bg-teal-500 hover:bg-teal-600 text-white font-medium py-2.5 px-4 rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancel", root_path, class: "flex-1 text-center bg-slate-700/50 hover:bg-slate-700 text-slate-300 font-medium py-2.5 px-4 rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
